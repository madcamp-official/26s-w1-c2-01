APP_ENV=development
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/app
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
CORS_ALLOW_ORIGINS=http://localhost:5173

# 추천 단어 생성용 Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
GEMINI_API_KEY=
# 무료 티어는 모델별 할당량이 자주 바뀌므로, 코드 수정 없이 여기서만 바꿔가며 쓸 수 있다
# (사용 가능한 모델 목록/한도: https://aistudio.google.com/rate-limit)
# 로컬 docker-compose는 이 값을 docker-compose.yml의 environment로 덮어써서 항상
# gemini-3.1-flash-lite를 씀 (배포 서버의 .env는 git으로 관리되지 않아 여기 값을 바꿔도
# 자동 반영되지 않으므로, 코드 저장소에 있는 docker-compose.yml 쪽을 우선시킨다)
GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_MODEL이 할당량 초과 등으로 실패하면 순서대로 자동 시도할 모델들(콤마 구분).
GEMINI_FALLBACK_MODELS=gemini-3.5-flash

